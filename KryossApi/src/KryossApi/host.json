{
    "version": "2.0",
    "extensions": {
        "http": {
            "routePrefix": ""
        }
    },
    "logging": {
        "logLevel": {
            "Default": "Information",
            "Microsoft.Extensions.Diagnostics.HealthChecks": "None",
            "Azure.Core": "Warning",
            "Microsoft.Azure.WebJobs.Script.WebHost.HealthMonitor": "None"
        },
        "applicationInsights": {
            "samplingSettings": {
                "isEnabled": true,
                "excludedTypes": "Request"
            },
            "enableLiveMetricsFilters": true
        }
    }
}